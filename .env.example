# AI Scraping Stack — Environment Config
# cp .env.example .env

# ── Core
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenRouter SDK (free tier available)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── FREE providers
# Jina Reader — 10M free tokens on signup, works without key
# https://jina.ai/  →  usage: r.jina.ai/<url>  |  s.jina.ai/<query>
JINA_API_KEY=jina_...

# Firecrawl — self-hosted free, $16/mo hosted
# https://firecrawl.dev/
FIRECRAWL_API_KEY=fc-...

# ── CHEAP paid ($0.0002–0.0005/req)
# Scrapingdog — fastest (5s avg), 1000 free credits — https://scrapingdog.com
SCRAPINGDOG_KEY=...
# ScraperAPI — 40M IPs, 1000 free req/mo — https://scraperapi.com
SCRAPERAPI_KEY=...
# ZenRows — 100 free credits — https://zenrows.com
ZENROWS_KEY=...
# ScrapingBee — AI markdown output — https://scrapingbee.com
SCRAPINGBEE_KEY=...
# Scrape.do — $29/mo FLAT (unlimited!) — https://scrape.do
SCRAPEDO_KEY=...

# ── Enterprise (optional)
BRIGHTDATA_KEY=...
ZYTE_API_KEY=...

# ── Custom LLM APIs (OpenAI-compatible)
# Groq — ultra-fast, free tier — https://console.groq.com
GROQ_API_KEY=gsk_...
# Together.ai — open models — https://together.ai
TOGETHER_API_KEY=...
# Perplexity — online search models — https://perplexity.ai
PERPLEXITY_API_KEY=pplx-...
# DeepInfra — cheap GPU inference
DEEPINFRA_API_KEY=...
# Fireworks.ai
FIREWORKS_API_KEY=fw_...

# ── Proxy (optional)
# http://user:pass@host:port  or  socks5://user:pass@host:port
PROXY_URL=
